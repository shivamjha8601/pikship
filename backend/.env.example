# Copy to .env (which is .gitignore'd) and edit for local.

PIKSHIPP_ROLE=all
PIKSHIPP_HTTP_ADDR=:8080
PIKSHIPP_LOG_LEVEL=debug
PIKSHIPP_VERSION=dev

# DB: app role used by the running binary. Migrations use a superuser URL
# (configured in the Makefile, not here).
PIKSHIPP_DATABASE_URL=postgres://pikshipp_dev:dev@127.0.0.1:5432/pikshipp_dev?sslmode=disable

# Pool sizing per role (api vs worker should run as separate processes
# in prod; in --role=all both pools are instantiated in one process).
PIKSHIPP_DB_APP_MAX_CONNS=50
PIKSHIPP_DB_APP_MIN_CONNS=5
PIKSHIPP_DB_REPORTS_MAX_CONNS=10
PIKSHIPP_DB_ADMIN_MAX_CONNS=5
PIKSHIPP_DB_STATEMENT_TIMEOUT=5s

# S3 (LocalStack in dev)
PIKSHIPP_S3_REGION=ap-south-1
PIKSHIPP_S3_ENDPOINT=http://localhost:4566
PIKSHIPP_S3_BUCKET=pikshipp-dev
PIKSHIPP_S3_FORCE_PATH_STYLE=true

# Google OAuth — leave CLIENT_ID empty to disable (the /v1/auth/google/* routes
# return 503 in that case and only /v1/auth/dev-login works). Get values from
# console.cloud.google.com → APIs & Services → Credentials → OAuth client ID.
PIKSHIPP_GOOGLE_OAUTH_CLIENT_ID=
PIKSHIPP_GOOGLE_OAUTH_CLIENT_SECRET=
PIKSHIPP_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8081/v1/auth/google/callback
PIKSHIPP_GOOGLE_OAUTH_FRONTEND_RETURN_URL=http://localhost:3000/auth/callback

# Session HMAC key — replace before staging.
PIKSHIPP_SESSION_HMAC_KEY=dev-256-bit-hmac-key-replace-in-prod-please-do-not-use

# Vendor stubs
PIKSHIPP_RAZORPAY_KEY_ID=rzp_test_dev
PIKSHIPP_RAZORPAY_KEY_SECRET=rzp_secret_dev
PIKSHIPP_DELHIVERY_API_KEY=dev-stub
PIKSHIPP_DELHIVERY_BASE_URL=https://staging-express.delhivery.com
PIKSHIPP_MSG91_AUTH_KEY=dev-stub
PIKSHIPP_SES_FROM_EMAIL=noreply@dev.pikshipp.local
